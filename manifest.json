{
  "manifest_version": 3,
  "name": "Leboncoin Bumper",
  "version": "0.1.0",
  "description": "Republie automatiquement tes annonces leboncoin chaque semaine + veille passive sur les demandes tech récentes.",
  "permissions": [
    "storage",
    "alarms",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://www.leboncoin.fr/*",
    "https://api.leboncoin.fr/*",
    "https://auth.leboncoin.fr/*",
    "https://img.leboncoin.fr/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Leboncoin Bumper"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
